rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read if authenticated
    match /allowedEmails/{email} {
      allow read: if request.auth != null;
    }
    
    // Allow users to read chats they're participants in
    match /chats/{chat} {
      allow read: if request.auth != null && 
        resource.data.participants.hasAny([request.auth.token.email]);
    }
    
    // Allow users to read/write messages in their chats
    match /messages/{message} {
      allow read, create: if request.auth != null;
    }
    
    // Allow users to read members
    match /members/{member} {
      allow read: if request.auth != null;
    }
  }
}