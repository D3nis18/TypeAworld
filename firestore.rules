rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read allowedEmails for login validation
    // This is safe because it only reveals which emails are allowed, not sensitive data
    match /allowedEmails/{email} {
      allow read: if true;
    }

    // Allow users to read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to read chats they're participants in
    // Admin can read all chats
    match /chats/{chat} {
      allow read: if request.auth != null && (
        request.auth.token.email == 'denismwg4@gmail.com' ||
        resource.data.participants.hasAny([request.auth.token.email])
      );
      allow create: if request.auth != null;
    }

    // Allow users to read messages in chats they're participants in
    match /messages/{message} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Allow authenticated users to read members
    // Allow admin to write to members (for permission updates)
    match /members/{member} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'denismwg4@gmail.com';
    }
  }
}